{
    "compilerOptions": {
        "jsx": "preserve",
        "strict": true,
        "module": "ESNext",
        "target": "ESNext",
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./dist/esm",
        "rootDir": "./src/ts",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["./src/ts/**/*"]
}
